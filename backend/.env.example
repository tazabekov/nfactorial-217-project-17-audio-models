# Copy this file to .env and fill in the keys you actually use.

# --- LLM (agent brain) ---
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- ASR (speech-to-text) ---
ASR_PROVIDER=openai          # openai | faster_whisper
ASR_MODEL=whisper-1
FASTER_WHISPER_MODEL_SIZE=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

# --- TTS (text-to-speech) ---
TTS_PROVIDER=elevenlabs      # elevenlabs | openai
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# --- MCP Playwright (web search tool for the agent) ---
MCP_ENABLED=true
MCP_PLAYWRIGHT_COMMAND=npx
MCP_PLAYWRIGHT_ARGS=["-y", "@playwright/mcp@latest"]

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
